<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.shelterfinder.presentation.ui.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_updateCheck"
            app:destination="@id/updateCheckFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/updateCheckFragment"
        android:name="com.example.shelterfinder.presentation.ui.UpdateCheckFragment"
        android:label="UpdateCheck">
        <action
            android:id="@+id/action_updateCheck_to_list"
            app:destination="@id/shelterListFragment" />
    </fragment>

    <fragment
        android:id="@+id/shelterListFragment"
        android:name="com.example.shelterfinder.presentation.ui.ShelterListFragment"
        android:label="Shelter List" />
</navigation>